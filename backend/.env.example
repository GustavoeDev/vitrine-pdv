DJANGO_ENV=local
DEBUG=True

SECRET_KEY=django-insecure-dev-only

DB_NAME=vitrine_pdv
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

ENABLE_API_DOCS=true

# Desenvolvimento com Expo Go no celular:
# Opção A — só o banco no Docker:
#   docker compose up -d db
#   uv run python manage.py migrate
#   uv run uvicorn core.asgi:application --host 0.0.0.0 --port 8000 --reload
#
# Opção B — API + banco no Docker:
#   docker compose up --build
#   API em http://localhost:8000
#
# Opção C — stack prod-like local (API + Nginx + banco):
#   cp .env.production.example .env
#   echo "DOCKER_IMAGE=vitrine-pdv-api:local" >> .env
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up --build
#   API em http://localhost:8080
#
# Documentação da API (quando ENABLE_API_DOCS=true):
#   Swagger UI  -> http://localhost:8000/api/v1/docs/
#   ReDoc       -> http://localhost:8000/api/v1/docs/redoc/
#
# WebSocket: ws://<host>/ws/notifications/?token=<access_token>

# Desenvolvimento com Expo Go no celular:
# docker compose up -d db
# uv run python manage.py migrate
# uv run uvicorn core.asgi:application --host 0.0.0.0 --port 8000 --reload
#
# Documentação da API:
#   Swagger UI  -> http://localhost:8000/api/v1/docs/
#   ReDoc       -> http://localhost:8000/api/v1/docs/redoc/
#   OpenAPI JSON -> http://localhost:8000/api/v1/schema/
#
# WebSocket de notificações: ws://<host>/ws/notifications/?token=<access_token>
# Channel layer em memória (1 worker uvicorn).

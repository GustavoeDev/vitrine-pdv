# URL base da API Django.
#
# Desenvolvimento local (Expo Go):
EXPO_PUBLIC_API_URL=http://192.168.x.x:8000/api/v1
#
# Build EAS (preview): defina aqui e envie para a nuvem com:
#   eas env:push --environment preview --path .env
# Ou crie direto:
#   eas env:create --name EXPO_PUBLIC_API_URL --value "http://SEU_IP/api/v1" --environment preview --visibility plaintext
